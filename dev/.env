LOG_LEVEL=debug
APP_NAME=email-service
ENVIRONMENT=develop
DEV_MODE=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_IDEMPOTENCY_TTL_SEC=86400

NATS_HOST=localhost
NATS_PORT=4222
NATS_STREAM=VERIFICATION
NATS_CONSUMER_NAME=email-service
NATS_ACK_WAIT_SEC=30
NATS_MAX_DELIVER=10
NATS_VERIFICATION_CREATED_SUBJECT=verification.email.created
NATS_DELIVERY_FAILED_SUBJECT=verification.email.delivery_failed

##SMTP_HOST=localhost
##SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.local
SMTP_SUBJECT=Подтверждение регистрации
SMTP_MESSAGE_TEMPLATE=Здравствуйте.\n\nДля подтверждения регистрации перейдите по ссылке:\n{{verification_link}}
SMTP_SEND_TIMEOUT_MS=5000

BASE_VERIFY_URL=http://localhost:8080

HMAC_SIGNATURE=base64_key_here